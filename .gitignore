# Keep the repository focused on durable documentation, source scaffolds, and tools.

# ROMs and extracted game data must not be committed.
*.sfc
*.smc
*.fig
*.bin
*.rom
*.spc
*.wav
*.pcm
*.brr
*.brstm
*.flac
*.ogg
*.mp3
*.zip
*.7z
*.rar
*.srm
*.sav
*.mss
*.zst
baserom/
asm/
dumps/

# Local scratch/probe files.
tmp_*.asm
tmp*.asm
*.tmp
*.bak

# Generated validation/build output. Regenerate from tools/ and notes/src state.
build/

# Local inbox / automation scratch.
inbox/

# Vendored/reference checkouts are useful locally but should be curated before publishing.
refs/*
!refs/earthbound-sounddriver-byte-perfect/
!refs/earthbound-sounddriver-byte-perfect/**

# Python/editor/system noise.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Encyclopedia app local dependencies and packaged build artifacts.
encyclopedia/node_modules/
encyclopedia/dist/
encyclopedia/dist-*/
encyclopedia/.electron/
encyclopedia/.vite/
encyclopedia/.cache/
encyclopedia/out/

# Local environment and logs.
.env
.env.*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep generated ROM/user media out of source control. The app can regenerate these
# from a verified local ROM; checked-in manifests and source-safe contracts are OK.
*.wav
*.spc
*.brr
*.gfx
*.pal
*.arr
*.lzhal
*.asar.unpacked/
